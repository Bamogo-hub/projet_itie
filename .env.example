# Copier ce fichier en .env et remplir les valeurs

# PostgreSQL — obtenir l'URL depuis Render Dashboard > PostgreSQL > Connection String
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Clé secrète Flask (générer une longue chaîne aléatoire)
SECRET_KEY=changez-moi-avec-une-longue-chaine-aleatoire-securisee

# Dossier upload (sur Render utiliser /tmp/uploads)
UPLOAD_FOLDER=uploads
